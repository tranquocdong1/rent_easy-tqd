datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  OWNER
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique @db.VarChar(255)
  passwordHash String     @db.Text
  fullName     String     @db.VarChar(150)
  avatarUrl    String?    @db.Text
  role         Role       @default(OWNER)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt       DateTime         @updatedAt
  refreshSessions RefreshSession[]
  properties      Property[]
  tenants         Tenant[]

  @@index([email])
}

enum AuditAction {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  PASSWORD_CHANGED
  TOKEN_REFRESH
  TOKEN_REUSE_DETECTED
  PROPERTY_CREATED
  PROPERTY_UPDATED
  PROPERTY_DELETED
  ROOM_CREATED
  ROOM_UPDATED
  ROOM_DELETED
  TENANT_CREATED
  TENANT_UPDATED
  TENANT_DELETED
}

enum RefreshSessionRevokeReason {
  LOGOUT
  PASSWORD_CHANGED
  TOKEN_REUSE
}

model RefreshSession {
  id             String                     @id @default(uuid())
  userId         String
  tokenHash      String                     @db.Text
  isRevoked      Boolean                    @default(false)
  expiresAt      DateTime
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  lastUsedAt     DateTime?
  rotatedAt      DateTime?
  revokedAt      DateTime?
  revokedReason  RefreshSessionRevokeReason?
  rotationCounter Int                       @default(0)

  user           User                       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([isRevoked])
}

model AuditLog {
  id        String      @id @default(uuid())
  userId    String
  action    AuditAction
  entity    String?
  entityId  String?
  metadata  Json?
  createdAt DateTime    @default(now())

  @@index([userId])
  @@index([createdAt])
}

enum PropertyType {
  HOUSE
  BOARDING_HOUSE
  MINI_APARTMENT
  OTHER
}

enum PropertyStatus {
  ACTIVE
  INACTIVE
}

model Property {
  id           String         @id @default(uuid())
  ownerId      String
  name         String         @db.VarChar(150)
  propertyType PropertyType
  status       PropertyStatus
  address      String         @db.VarChar(500)
  description  String?        @db.Text
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?

  owner        User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  rooms        Room[]

  @@index([ownerId])
  @@index([ownerId, status])
  @@index([ownerId, createdAt])
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
  INACTIVE
}

model Room {
  id          String     @id @default(uuid())
  propertyId  String
  code        String     @db.VarChar(50)
  name        String     @db.VarChar(150)
  floor       Int?
  area        Decimal    @db.Decimal(8, 2)
  capacity    Int
  rentPrice   Decimal    @db.Decimal(12, 2)
  deposit     Decimal    @db.Decimal(12, 2)
  status      RoomStatus
  description String?    @db.Text
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  property    Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([propertyId, status])
  @@index([propertyId, createdAt])
  @@index([propertyId, code])
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model Tenant {
  id                  String    @id @default(uuid())
  ownerId             String
  fullName            String    @db.VarChar(150)
  gender              Gender?
  dateOfBirth         DateTime?
  identityNumber      String    @db.VarChar(50)
  identityIssuedDate  DateTime?
  identityIssuedPlace String?   @db.VarChar(255)
  phone               String?   @db.VarChar(20)
  email               String?   @db.VarChar(255)
  permanentAddress    String?   @db.Text
  note                String?   @db.Text
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  owner               User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([ownerId, fullName])
  @@index([ownerId, phone])
  @@index([ownerId, identityNumber])
  @@index([ownerId, createdAt])
}
