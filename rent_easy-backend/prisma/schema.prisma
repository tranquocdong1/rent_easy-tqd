datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  OWNER
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique @db.VarChar(255)
  passwordHash String     @db.Text
  fullName     String     @db.VarChar(150)
  avatarUrl    String?    @db.Text
  role         Role       @default(OWNER)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt       DateTime         @updatedAt
  refreshSessions RefreshSession[]
  properties      Property[]
  tenants         Tenant[]

  @@index([email])
}

enum AuditAction {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  PASSWORD_CHANGED
  TOKEN_REFRESH
  TOKEN_REUSE_DETECTED
  PROPERTY_CREATED
  PROPERTY_UPDATED
  PROPERTY_DELETED
  ROOM_CREATED
  ROOM_UPDATED
  ROOM_DELETED
  TENANT_CREATED
  TENANT_UPDATED
  TENANT_DELETED
  CONTRACT_CREATED
  CONTRACT_UPDATED
  CONTRACT_DELETED
  CONTRACT_ACTIVATED
  CONTRACT_TERMINATED
  CONTRACT_EXPIRED
  INVOICE_CREATED
  INVOICE_UPDATED
  INVOICE_DELETED
}

enum RefreshSessionRevokeReason {
  LOGOUT
  PASSWORD_CHANGED
  TOKEN_REUSE
}

model RefreshSession {
  id             String                     @id @default(uuid())
  userId         String
  tokenHash      String                     @db.Text
  isRevoked      Boolean                    @default(false)
  expiresAt      DateTime
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  lastUsedAt     DateTime?
  rotatedAt      DateTime?
  revokedAt      DateTime?
  revokedReason  RefreshSessionRevokeReason?
  rotationCounter Int                       @default(0)

  user           User                       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([isRevoked])
}

model AuditLog {
  id        String      @id @default(uuid())
  userId    String
  action    AuditAction
  entity    String?
  entityId  String?
  metadata  Json?
  createdAt DateTime    @default(now())

  @@index([userId])
  @@index([createdAt])
}

enum PropertyType {
  HOUSE
  BOARDING_HOUSE
  MINI_APARTMENT
  OTHER
}

enum PropertyStatus {
  ACTIVE
  INACTIVE
}

model Property {
  id           String         @id @default(uuid())
  ownerId      String
  name         String         @db.VarChar(150)
  propertyType PropertyType
  status       PropertyStatus
  address      String         @db.VarChar(500)
  description  String?        @db.Text
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?

  owner        User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  rooms        Room[]

  @@index([ownerId])
  @@index([ownerId, status])
  @@index([ownerId, createdAt])
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
  INACTIVE
}

model Room {
  id          String     @id @default(uuid())
  propertyId  String
  code        String     @db.VarChar(50)
  name        String     @db.VarChar(150)
  floor       Int?
  area        Decimal    @db.Decimal(8, 2)
  capacity    Int
  rentPrice   Decimal    @db.Decimal(12, 2)
  deposit     Decimal    @db.Decimal(12, 2)
  status      RoomStatus
  description String?    @db.Text
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  property    Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  contracts   Contract[]

  @@index([propertyId])
  @@index([propertyId, status])
  @@index([propertyId, createdAt])
  @@index([propertyId, code])
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model Tenant {
  id                  String    @id @default(uuid())
  ownerId             String
  fullName            String    @db.VarChar(150)
  gender              Gender?
  dateOfBirth         DateTime?
  identityNumber      String    @db.VarChar(50)
  identityIssuedDate  DateTime?
  identityIssuedPlace String?   @db.VarChar(255)
  phone               String?   @db.VarChar(20)
  email               String?   @db.VarChar(255)
  permanentAddress    String?   @db.Text
  note                String?   @db.Text
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  owner               User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  contracts           Contract[]

  @@index([ownerId])
  @@index([ownerId, fullName])
  @@index([ownerId, phone])
  @@index([ownerId, identityNumber])
  @@index([ownerId, createdAt])
}

enum ContractStatus {
  PENDING
  ACTIVE
  EXPIRED
  TERMINATED
  CANCELLED
}

model Contract {
  id             String         @id @default(uuid())
  tenantId       String
  roomId         String
  contractNumber String         @unique @db.VarChar(50)
  startDate      DateTime
  endDate        DateTime
  monthlyRent    Decimal        @db.Decimal(12, 2)
  depositAmount  Decimal        @db.Decimal(12, 2)
  note           String?        @db.Text
  status         ContractStatus @default(PENDING)
  terminatedAt   DateTime?
  terminationReason String?     @db.Text
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  room           Room           @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([roomId])
  @@index([status])
  @@index([createdAt])
  invoices       Invoice[]
}

enum InvoiceStatus {
  DRAFT
  UNPAID
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

model Invoice {
  id             String         @id @default(uuid())
  contractId     String
  invoiceNumber  String         @unique @db.VarChar(50)
  billingMonth   Int
  billingYear    Int
  issueDate      DateTime
  roomRent       Decimal        @db.Decimal(12, 2)
  electricityAmount Decimal     @default(0) @db.Decimal(12, 2)
  waterAmount    Decimal        @default(0) @db.Decimal(12, 2)
  serviceAmount  Decimal        @default(0) @db.Decimal(12, 2)
  otherAmount    Decimal        @default(0) @db.Decimal(12, 2)
  discountAmount Decimal        @default(0) @db.Decimal(12, 2)
  totalAmount    Decimal        @db.Decimal(12, 2)
  paidAmount     Decimal        @default(0) @db.Decimal(12, 2)
  dueDate        DateTime
  note           String?        @db.Text
  status         InvoiceStatus  @default(DRAFT)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  contract       Contract       @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@index([status])
  @@index([createdAt])
  @@index([dueDate])
  @@index([billingMonth, billingYear])
  payments       Payment[]
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CREDIT_CARD
  OTHER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

model Payment {
  id             String         @id @default(uuid())
  invoiceId      String
  receiptNumber  String         @unique @db.VarChar(50)
  amount         Decimal        @db.Decimal(12, 2)
  paymentDate    DateTime
  paymentMethod  PaymentMethod
  status         PaymentStatus  @default(PENDING)
  note           String?        @db.Text
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  invoice        Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([status])
  @@index([createdAt])
  @@index([paymentDate])
}
